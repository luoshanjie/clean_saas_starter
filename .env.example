APP_ENV=dev

# Optional: override YAML config file path.
# APP_CONFIG_FILE=./app.yaml

ADDR=:8080
DB_DRIVER=postgres
DB_DSN=postgres://postgres:postgres@127.0.0.1:5432/service?sslmode=disable
# Reserved for upcoming SQLite bootstrap support.
# SQLITE_PATH=./var/service.db
SKIP_DB=0
JWT_SECRET=change-me-in-local-dev
AUTH_LOGIN_SECOND_FACTOR_ENABLED=false

OSS_ENDPOINT=127.0.0.1:9000
OSS_ACCESS_KEY=minioadmin
OSS_SECRET_KEY=minioadmin
OSS_BUCKET=service-dev
OSS_PUBLIC_BASE_URL=http://127.0.0.1:9000/service-dev
OSS_USE_SSL=false

UPLOAD_CLEANUP_ENABLED=true
UPLOAD_CLEANUP_INTERVAL_SEC=600
UPLOAD_CLEANUP_BATCH_SIZE=200

LOG_DIR=./logs
LOG_LEVEL=info
LOG_FORMAT=json
LOG_CONSOLE_FORMAT=text
LOG_CONSOLE=1
